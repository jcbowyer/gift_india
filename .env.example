# Copy to `.env` for local development. The app auto-loads this file.
#
#   cp .env.example .env

# Local Postgres (docker compose). The app reads from here when set.
GIFT_INDIA_DB_URL=postgresql://postgres:password@localhost:5433/gift_india

# Optional: override the schema the loader lands raw data in (defaults to
# "bronze"). dbt promotes bronze -> silver -> gold; serving reads gold.
# GIFT_INDIA_DB_SCHEMA=bronze

# NHPR / HFR facility registry (optional integrator credentials).
# Scraping uses the public portal XHR endpoints — no token required by default.
# ABDM_CLIENT_ID=
# ABDM_CLIENT_SECRET=
# ABDM_CM_ID=abdm
# ABDM_NHPR_BASE=https://nhpr.abdm.gov.in
