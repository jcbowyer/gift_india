# Copy to `.env` for local development. The app auto-loads this file.
#
#   cp .env.example .env

# Local Postgres — **system PostgreSQL on localhost:5432** (see claude.md; no Docker).
# dbt needs a password: put it in `.env.local` (see .env.local.example) or embed in the URL:
#   GIFT_INDIA_DB_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/gift_india
GIFT_INDIA_DB_URL=postgresql://postgres@localhost:5432/gift_india
GIFT_INDIA_PGHOST=localhost
GIFT_INDIA_PGPORT=5432
GIFT_INDIA_PGUSER=postgres
GIFT_INDIA_PGPASSWORD=
GIFT_INDIA_PGDATABASE=gift_india

# Optional: override the schema the loader lands raw data in (defaults to
# "bronze"). dbt promotes bronze -> silver -> gold; serving reads gold.
# GIFT_INDIA_DB_SCHEMA=bronze

# NHPR / HFR facility registry (optional integrator credentials).
# Scraping uses the public portal XHR endpoints — no token required by default.
# ABDM_CLIENT_ID=
# ABDM_CLIENT_SECRET=
# ABDM_CM_ID=abdm
# ABDM_NHPR_BASE=https://nhpr.abdm.gov.in
