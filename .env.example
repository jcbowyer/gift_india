# Copy to `.env` for local development. The app auto-loads this file.
#
#   cp .env.example .env

# Local Postgres (docker compose). The app reads from here when set.
GIFT_INDIA_DB_URL=postgresql://gift_india:gift_india@localhost:5432/gift_india

# Optional: override the schema the app reads (defaults to "public").
# GIFT_INDIA_DB_SCHEMA=public
