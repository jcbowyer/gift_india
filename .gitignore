# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/

# Generated data (regenerated deterministically by src/data.py)
data/*.csv
# …but the curated JCI seed is a hand-maintained SOURCE input, not generated —
# keep it tracked so `make jci` works on a clean checkout.
!data/jci_india_seed.csv

# Scraped website snapshots (regenerated by src/scraper.py / jci_scraper.py)
data/scraped/
data/jci/scraped/
# Regenerable JCI scraper outputs (rebuilt from the tracked seed by `make jci`).
data/jci/*.json

# SOI shapefiles from SimplyGIS — large binaries, re-downloadable via
# `python -m src.load_shapefiles --download` (or `make shapefiles DOWNLOAD=1`).
data/simplygis/
.soi_shapefiles/

# dbt (gift_india_dbt) build artifacts
gift_india_dbt/target/
gift_india_dbt/dbt_packages/
gift_india_dbt/logs/
gift_india_dbt/.user.yml

# OS / editor
.DS_Store
.ipynb_checkpoints/
.streamlit/secrets.toml
