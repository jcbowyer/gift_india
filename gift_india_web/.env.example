# ── Local development ─────────────────────────────────────────────────────────
# Set GIFT_INDIA_DB_URL to serve from the local Postgres warehouse (the gift_india
# database dbt builds, already running on localhost:5433). When this is set and
# NODE_ENV != production, the app skips Lakebase entirely — no Databricks auth
# needed. Leave it unset to connect to Lakebase instead.
GIFT_INDIA_DB_URL=postgresql://postgres:password@localhost:5433/gift_india

# ── Lakebase (deployed / when GIFT_INDIA_DB_URL is unset) ─────────────────────
DATABRICKS_HOST=https://...
PGDATABASE=your_postgres_databaseName
LAKEBASE_ENDPOINT=your_postgres_endpointPath
PGHOST=your_postgres_host
PGPORT=5432
PGSSLMODE=require
DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=gift-india-web
FLASK_RUN_HOST=0.0.0.0
