# Copy to `.env` for local development. The app auto-loads this file.
#
#   cp .env.example .env

# Local Postgres — comment out to use published Virtue data on Lakebase instead.
# GIFT_INDIA_DB_URL=postgresql://postgres:password@localhost:5433/gift_india
GIFT_INDIA_PGHOST=localhost
GIFT_INDIA_PGPORT=5433
GIFT_INDIA_PGUSER=postgres
GIFT_INDIA_PGPASSWORD=password
GIFT_INDIA_PGDATABASE=gift_india

# Optional: override the schema the loader lands raw data in (defaults to
# "bronze"). dbt promotes bronze -> silver -> gold; serving reads gold.
# GIFT_INDIA_DB_SCHEMA=bronze

# Lakebase — published Virtue Foundation gold.* (same as deployed app)
DATABRICKS_CONFIG_PROFILE=gift-india-mb
LAKEBASE_ENDPOINT=projects/gift-india/branches/production/endpoints/primary
PGHOST=ep-raspy-cloud-d8jh2bpy.database.us-east-2.cloud.databricks.com
PGPORT=5432
PGDATABASE=gift_india
PGSSLMODE=require
DATABRICKS_GENIE_SPACE_ID=01f169cdad431edda9398a861bdba2d1
DATABRICKS_GIFT_GENIE_SPACE_ID=01f169cdad431edda9398a861bdba2d1
