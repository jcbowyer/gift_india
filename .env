# Copy to `.env` for local development. The app auto-loads this file.
#
#   cp .env.example .env

# Local Postgres — Docker warehouse on localhost:5433 (password matches docker-compose).
GIFT_INDIA_DB_URL=postgresql://postgres:password@localhost:5433/gift_india
GIFT_INDIA_PGHOST=localhost
GIFT_INDIA_PGPORT=5433
GIFT_INDIA_PGUSER=postgres
GIFT_INDIA_PGPASSWORD=
GIFT_INDIA_PGDATABASE=gift_india

# Optional: override the schema the loader lands raw data in (defaults to
# "bronze"). dbt promotes bronze -> silver -> gold; serving reads gold.
# GIFT_INDIA_DB_SCHEMA=bronze

# Databricks Genie (gift-india-mb workspace) — enables Ask Genie on the scorecard.
# Only Genie space on this workspace today; create a GIFT gold.* space in AI/BI for facility data.
DATABRICKS_CONFIG_PROFILE=gift-india-mb
DATABRICKS_GENIE_SPACE_ID=01f168d3088f1f4383c33d1838019847
