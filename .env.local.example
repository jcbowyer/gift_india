# Copy to `.env.local` (gitignored) for secrets that should not be committed.
#
#   cp .env.local.example .env.local
#
# System Postgres on localhost:5432 requires a password for dbt (`make dbt`).
GIFT_INDIA_PGPASSWORD=your_system_postgres_password

# Or embed the password in the URL (synced to GIFT_INDIA_PG* automatically):
# GIFT_INDIA_DB_URL=postgresql://postgres:your_system_postgres_password@localhost:5432/gift_india
